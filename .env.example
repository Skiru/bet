# Environment variables for Kilo Code MCP servers
# Copy to .env and fill in values, OR set in fish shell: set -x VAR value

# Brave Search API key (for brave-search MCP server)
# Get yours at: https://brave.com/search/api/
BRAVE_API_KEY=your_brave_api_key_here

# Google AI Studio API key (for Kilo Code Gemini 2.5 Flash)
# Get yours at: https://aistudio.google.com/apikey
# NOTE: This is configured in Kilo Code extension settings, not as env var
# GOOGLE_AI_API_KEY=your_key_here
