  "mcp": {
    "brave-search": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@brave/brave-search-mcp-server@2.0.75",
        "--transport",
        "stdio"
      ],
      "environment": {
        "BRAVE_API_KEY": "{env:BRAVE_API_KEY}"
      },
      "enabled": true,
      "timeout": 30000
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "timeout": 20000
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@0.0.76",
        "--headless"
      ],
      "enabled": false,
      "timeout": 30000
    }
  },
  "experimental": {
    "batch_tool": false
  },
  "watcher": {
    "ignore": [
      ".git/**",
      ".venv/**",
      ".venv-*/**",
      "**/__pycache__/**",
      "**/.pytest_cache/**",
      "**/.mypy_cache/**",
      "**/.ruff_cache/**",
      "**/node_modules/**",
      ".kilo/artifacts/**",
      ".kilo/logs/**",
      ".kilo/runtime/**",
      "reports/**",
      "downloaded_files/**",
      "betting/data/*.db",
      "betting/data/*.db-*",
      "betting/data/*.db-journal",
      "betting/data/*.db-wal",
      "betting/data/*.db-shm"
    ]
  },
  "compaction": {
    "auto": false,
    "threshold_percent": 72,
    "prune": true,
    "tail_turns": 1,
    "preserve_recent_tokens": 2000,
    "reserved": 6144
  }
}
